body {
    font-family: Arial, sans-serif;
    background: #f4f6f9;
    margin: 0;
    padding: 20px;
    text-align: center;
}

h1 {
    color: #1e3a8a;
}

input,
select,
button {
    width: 90%;
    max-width: 350px;
    padding: 12px;
    margin: 8px;
    border-radius: 8px;
    border: 1px solid #ccc;
    font-size: 16px;
}

button {
    background: #2563eb;
    color: white;
    border: none;
    cursor: pointer;
}

button:hover {
    background: #1d4ed8;
}

ul {
    list-style: none;
    padding: 0;
}

li {
    background: white;
    margin: 12px auto;
    padding: 15px;
    width: 90%;
    max-width: 450px;
    border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    text-align: left;
}

li button {
    background: #dc2626;
    margin-top: 10px;
    width: auto;
    padding: 8px 15px;
}

h3 {
    color: green;
    font-size: 22px;
}